# ===========================================================================
# Automated Insurance Claim Approval Engine - Environment configuration
# ===========================================================================
# Copy this file to ".env" and fill in real values for a production / staging
# deployment. When credentials are omitted, the engine runs in MOCK_MODE so
# that the full pipeline can be exercised locally and in CI without any
# external services.
# ---------------------------------------------------------------------------

# --- Runtime ----------------------------------------------------------------
# When true, all external integrations (Claude, Pinecone, Snowflake) are
# replaced with deterministic in-memory fakes. Set to "false" in production.
CLAIM_ENGINE_MOCK_MODE=true
CLAIM_ENGINE_ENVIRONMENT=local          # local | dev | staging | prod
CLAIM_ENGINE_LOG_LEVEL=INFO

# --- Anthropic Claude -------------------------------------------------------
ANTHROPIC_API_KEY=
CLAIM_ENGINE_CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAIM_ENGINE_CLAUDE_MAX_TOKENS=1024
CLAIM_ENGINE_CLAUDE_TEMPERATURE=0.0

# --- Pinecone (vector database) ---------------------------------------------
PINECONE_API_KEY=
CLAIM_ENGINE_PINECONE_INDEX=insurance-policy-kb
CLAIM_ENGINE_PINECONE_CLOUD=aws
CLAIM_ENGINE_PINECONE_REGION=us-east-1
CLAIM_ENGINE_EMBEDDING_DIMENSION=1536

# --- Snowflake (data warehouse) ---------------------------------------------
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=CLAIMS_WH
SNOWFLAKE_DATABASE=INSURANCE
SNOWFLAKE_SCHEMA=CLAIMS

# --- Decision policy --------------------------------------------------------
# Minimum model confidence required to auto-approve without human review.
CLAIM_ENGINE_AUTO_APPROVE_THRESHOLD=0.90
# Confidence below which a claim is auto-routed to manual review.
CLAIM_ENGINE_MANUAL_REVIEW_THRESHOLD=0.60
# Claim amount (in INR) above which human sign-off is always required.
CLAIM_ENGINE_HIGH_VALUE_THRESHOLD=500000
